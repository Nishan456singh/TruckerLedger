{
  "expo": {
    "name": "TruckerLedger",
    "slug": "truckerledger",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "truckerledger",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.nishan.truckerledger",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "TruckerLedger uses the camera to scan receipts.",
        "NSPhotoLibraryUsageDescription": "TruckerLedger accesses your photos to attach receipts.",
        "NSPhotoLibraryAddUsageDescription": "TruckerLedger saves receipt images to your photo library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F1115",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-apple-authentication",
      [
        "expo-camera",
        {
          "cameraPermission": "TruckerLedger uses the camera to scan receipts."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "TruckerLedger accesses your photos to attach receipts."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0F1115"
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
